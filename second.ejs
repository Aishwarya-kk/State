<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="seond.css">
    <title>Document</title>
     <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
   <style>
     
    .conatiner{
        display: flex;
    justify-content: center;
    width:600px;
    height: 600px;
   
    margin-left:900px;
    margin-top:120px;
    border-radius: 5%;
    background-color:rgba(128, 128, 128, 0.478);
   
    }
    .conatiner:hover{
        display: flex;
    justify-content: center;
    width:600px;
    height: 600px;
   box-shadow: 5px 5px 50px rgb(14, 14, 15);
    margin-left:500px;
    margin-top:90px;
    transition: margin-top 2s ease-in-out 0.9s;
    border-radius: 5%;
    background-color:rgba(74, 73, 71, 0.615);
   
    }
    .input{
        margin:150px;
    }
    input{
        border-radius: 50%;
        width:350px;
        height: 40px;
        padding: 2px;
        background-color: rgba(231, 236, 236, 0.255);
        color: black;
    }
    input:hover{
        border-radius: 50%;
        width:350px;
        height: 40px;
        padding: 2px;
        box-shadow: 4px 4px 30px white;
         color: black;
    }
    #b{
        margin-left:200px;
        
    }
   h1{
       font-size: 50px;
        font-style: oblique;
 font-weight:bold;
  text-align: center;
  color: black;
  margin-top:0;
  animation: wave 2s infinite ease-in-out;
}
@keyframes wave {
  0%,100%{transform: rotate(0deg);}
  25%{transform: rotate(5deg);}
  75%{transform: rotate(-5deg);}

}
.form-inline {
  
    margin-left: 1000px;
}
.btn {
    display: inline;
}
.nav{
    background-color: black;
    color: white;
}
.nav:hover{
    box-shadow: 2px 2px 10px blue;
}
    
   </style>
</head>
<body>
   

     <h1>Sing UP</h1>
   <div class="conatiner" id="a">

    <form method="GET" action="/resume/third" class="md-8">
        <div class="input">
        <input placeholder="             enter user name" name="name" class="from-control">
        <br>
         <br> 
        <input type="email" placeholder="                      enter a email" name="email" class="from-control">
        <br>
         <br>
        <input type="password" placeholder="                     enter a password" name="password" class="from-control">
        <br>
         <br>
         <br>
        <button class="btn btn-primary">Save</button>
        <button class="btn btn-primary" id="b">Submit</button>
        </div>
         </form>
   
   </div>
</body>
</html>